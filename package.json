{
  "name": "awsibnj",
  "version": "1.0.1",
  "description": "HTTP client and Axios replacement with intelligent API field-name transformation (camelCase/snake_case/PascalCase/kebab-case), auto-retry, response caching, request deduplication, token refresh, lifecycle hooks, pluggable adapters, circuit breaker, security hardening (SSRF, CRLF, rate limiting, replay detection, input sanitization, RBAC, HMAC signing, mTLS), and 90+ modules",
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": "./src/index.js",
    "./core": "./src/core/index.js",
    "./utils": "./src/utils/index.js",
    "./adapters": "./src/adapters/index.js",
    "./errors": "./src/core/errors.js",
    "./package.json": "./package.json"
  },
  "files": [
    "src/",
    "types/",
    "examples/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node test.js",
    "example": "node examples/basic-usage.js",
    "example:advanced": "node examples/advanced-usage.js",
    "example:plugins": "node examples/plugin-example.js",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "api",
    "http-client",
    "axios",
    "axios-replacement",
    "fetch",
    "transformer",
    "camelCase",
    "snake_case",
    "schema",
    "type-coercer",
    "fuzzy-matcher",
    "circuit-breaker",
    "retry",
    "cache",
    "deduplication",
    "token-refresh",
    "interceptor",
    "rate-limiter",
    "ssrf-protection",
    "input-sanitization",
    "rbac",
    "hmac-signing",
    "mutual-tls",
    "security-hardening",
    "typescript",
    "plugin",
    "sdk"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/api-bridges/Api_bridge.git"
  },
  "bugs": {
    "url": "https://github.com/api-bridges/Api_bridge/issues"
  },
  "homepage": "https://github.com/api-bridges/Api_bridge#readme",
  "author": "awsibnj",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "fastest-levenshtein": "^1.0.16"
  }
}
